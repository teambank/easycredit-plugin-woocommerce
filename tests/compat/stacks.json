{
  "stacks": [
    {
      "id": "german-market",
      "label": "German Market",
      "runOnLatest": false,
      "manualOnly": true,
      "localPlugins": [
        "woocommerce-german-market"
      ],
      "plugins": [],
      "options": {},
      "setupGermanMarketLegal": true,
      "spec": "compat/specs/german-market*.spec.ts"
    },
    {
      "id": "germanized",
      "label": "Germanized",
      "runOnLatest": true,
      "localPlugins": [
        "woocommerce-germanized"
      ],
      "plugins": [
        "woocommerce-germanized"
      ],
      "options": {
        "woocommerce_gzd_checkout_stop_order_cancellation": "yes",
        "woocommerce_gzd_disable_instant_order_confirmation": "no"
      },
      "setupGermanizedLegal": true,
      "spec": "compat/specs/germanized*.spec.ts"
    }
  ]
}
